{
  "name": "e2e-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "lingui:extract": "lingui extract --config lingui.config.ts --workers 1 --clean --overwrite",
    "lingui:compile": "lingui compile --config lingui.config.ts --workers 1 && prettier --write src/lib/i18n/locales",
    "lingui:build": "pnpm run lingui:extract && pnpm run lingui:compile",
    "build": "pnpm run lingui:build && svelte-kit sync && vite build",
    "preview": "node .sveltekit-build/index.js",
    "check": "pnpm run check:ts && pnpm run check:svelte",
    "check:svelte": "svelte-check --tsconfig ./tsconfig.json",
    "check:ts": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:e2e run && pnpm run test:browser run",
    "test:e2e": "vitest",
    "test:browser": "vitest --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@lingui/core": "^5.9.3",
    "lingui-for-svelte": "workspace:*",
    "svelte": "^5.53.12"
  },
  "devDependencies": {
    "@lingui/cli": "^5.9.3",
    "@lingui/conf": "^5.9.3",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.0",
    "daisyui": "^5.5.19",
    "playwright": "^1.58.2",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
