{
  "name": "e2e-svelte",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "lingui:extract": "vp exec lingui extract --clean --overwrite",
    "lingui:compile": "vp exec lingui compile && vp fmt src/lib/i18n/locales",
    "lingui:build": "vp run lingui:extract && vp run lingui:compile",
    "build": "vp run lingui:build && vp exec svelte-kit sync && vp build",
    "preview": "vp exec node .sveltekit-build/index.js",
    "check": "vp run check:ts && vp run check:markup",
    "check:ts": "vp exec tsc --noEmit",
    "check:markup": "vp exec svelte-check",
    "test": "vp run test:e2e run && vp run test:browser run",
    "test:e2e": "vp test",
    "test:browser": "vp test --config vitest.browser.config.ts"
  },
  "dependencies": {
    "@lingui/core": "^5.9.3",
    "lingui-for-svelte": "workspace:*",
    "svelte": "^5.54.0"
  },
  "devDependencies": {
    "@lingui/cli": "^5.9.3",
    "@lingui/conf": "^5.9.3",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "daisyui": "^5.5.19",
    "playwright": "^1.58.2",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "unplugin-lingui-macro": "workspace:*",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
