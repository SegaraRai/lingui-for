{
  "name": "e2e-astro",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "lingui:extract": "lingui extract --clean --overwrite",
    "lingui:compile": "lingui compile && vp fmt src/lib/i18n/locales",
    "lingui:build": "pnpm run lingui:extract && pnpm run lingui:compile",
    "build": "pnpm run lingui:build && astro build",
    "preview": "astro preview --port 4542",
    "check": "pnpm run check:ts && pnpm run check:markup",
    "check:ts": "tsc --noEmit",
    "check:markup": "astro check",
    "pretest": "pnpm run build",
    "test": "vp test run"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.3",
    "@astrojs/react": "^5.0.1",
    "@astrojs/svelte": "^8.0.3",
    "@lingui/core": "^5.9.3",
    "@lingui/react": "^5.9.3",
    "astro": "^6.0.7",
    "lingui-for-astro": "workspace:*",
    "lingui-for-svelte": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svelte": "^5.54.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.7",
    "@lingui/cli": "^5.9.3",
    "@lingui/conf": "^5.9.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro-strip-whitespace": "^0.2.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "unplugin-lingui-macro": "workspace:*",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
