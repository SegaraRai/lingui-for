---
import { t } from "lingui-for-astro/macro";

import AppLayout from "../layouts/AppLayout.astro";
import { getLocaleLabel } from "../lib/i18n/runtime";

const locale = Astro.locals.locale;
const localeLabel = getLocaleLabel(locale);
const currentPage = t`Server page`;
---

<AppLayout
  title={t`Server translation checks`}
  locale={locale}
  pathname={Astro.url.pathname}
  currentPage={currentPage}
>
  <section class="card border-base-300 bg-base-100 border shadow-xl">
    <div class="card-body gap-4">
      <p class="badge badge-primary badge-outline flex-none">
        {t`Server`}
      </p>
      <h1 class="text-3xl font-black tracking-tight">
        {t`Astro pages render request-scoped translations through locals.`}
      </h1>
      <p class="text-base-content/70">
        {
          t`The layout, page body, and locale badge all resolve from the request-bound Lingui instance.`
        }
      </p>
    </div>
  </section>

  <section class="card border-base-300 bg-base-100 border shadow-lg">
    <div class="card-body">
      <h2 class="card-title">
        {t`This paragraph was translated directly inside a .astro page.`}
      </h2>
      <p class="text-base-content/70">
        {
          t`The current locale label is ${localeLabel}, and it comes from the same request.`
        }
      </p>
    </div>
  </section>
</AppLayout>
