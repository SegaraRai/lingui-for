---
import { t } from "lingui-for-astro/macro";

import AppLayout from "../layouts/AppLayout.astro";
import ReactLinguiIsland from "../components/react/ReactLinguiIsland.tsx";
import SvelteLinguiIsland from "../components/svelte/SvelteLinguiIsland.svelte";

const locale = Astro.locals.locale;
const currentPage = t`Islands page`;
---

<AppLayout
  title={t`Island translation checks`}
  locale={locale}
  pathname={Astro.url.pathname}
  currentPage={currentPage}
>
  <section class="card border-base-300 bg-base-100 border shadow-xl">
    <div class="card-body gap-4">
      <p class="badge badge-primary badge-outline flex-none">
        {t`Islands`}
      </p>
      <h1 class="text-3xl font-black tracking-tight">
        {t`Svelte and React islands read the same active locale.`}
      </h1>
      <p class="text-base-content/70">
        {
          t`Each island creates its own runtime, but Astro middleware hands both the same locale.`
        }
      </p>
    </div>
  </section>

  <div class="grid gap-4 lg:grid-cols-2">
    <SvelteLinguiIsland client:load locale={locale} />
    <ReactLinguiIsland client:load locale={locale} />
  </div>
</AppLayout>
