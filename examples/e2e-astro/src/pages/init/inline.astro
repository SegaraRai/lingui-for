---
import { setLinguiContext } from "lingui-for-astro";
import { t } from "lingui-for-astro/macro";

import { LOCALE_COOKIE, resolveLocale } from "../../lib/i18n/locale";
import { createAppI18n } from "../../lib/i18n/runtime";

// Initialize Lingui context directly in frontmatter -- same component as the
// macros that consume it. This is the pattern for pages that manage their own
// locale without relying on middleware.
const locale = resolveLocale(
  Astro.url.searchParams.get("lang"),
  Astro.cookies.get(LOCALE_COOKIE)?.value,
  Astro.request.headers.get("accept-language"),
);
setLinguiContext(Astro.locals, createAppI18n(locale));
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <title>{t`Inline initialization check`}</title>
  </head>
  <body>
    <h1>{t`Inline initialization check`}</h1>
    <p>{t`This page initializes Lingui in its own frontmatter.`}</p>
  </body>
</html>
