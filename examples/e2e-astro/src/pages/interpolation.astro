---
import { t } from "lingui-for-astro/macro";

import AppLayout from "../layouts/AppLayout.astro";

const locale = Astro.locals.locale;
const currentPage = t`Astro interpolation extraction page`;
---

<AppLayout
  title={t`Astro interpolation extraction checks`}
  locale={locale}
  pathname={Astro.url.pathname}
  currentPage={currentPage}
>
  <section class="card border-base-300 bg-base-100 border shadow-xl">
    <div class="card-body gap-4">
      <p class="badge badge-primary badge-outline flex-none">
        {t`Astro interpolation extraction`}
      </p>
      <h1 class="text-3xl font-black tracking-tight">
        {t`Astro interpolations can contain comments and fragments.`}
      </h1>
    </div>
  </section>

  <section class="card border-base-300 bg-base-100 border shadow-lg">
    <div class="card-body">
      <h2 class="card-title">{t`Comment-only interpolation neighbors`}</h2>
      <p>{t`Message before an HTML comment interpolation.`}</p>
      {<!-- html-comment-only-between-messages -->}
      <p>{t`Message after an HTML comment interpolation.`}</p>
      <p>{t`Message before a JavaScript comment interpolation.`}</p>
      {/* js-comment-only-between-messages */}
      <p>{t`Message after a JavaScript comment interpolation.`}</p>
    </div>
  </section>

  <section class="card border-base-300 bg-base-100 border shadow-lg">
    <div class="card-body">
      <h2 class="card-title">{t`Fragment-wrapped interpolation roots`}</h2>
      {
        <>
          <p>{t`First translated node inside an Astro fragment interpolation.`}</p>
          <p>{t`Second translated node inside an Astro fragment interpolation.`}</p>
        </>
      }
    </div>
  </section>
</AppLayout>
