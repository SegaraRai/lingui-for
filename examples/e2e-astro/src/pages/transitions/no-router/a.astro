---
import { t } from "lingui-for-astro/macro";

import TransitionShowcase from "../../../components/TransitionShowcase.astro";
import AppLayout from "../../../layouts/AppLayout.astro";

const locale = Astro.locals.locale;
const currentPage = t`Transition demo without ClientRouter`;
---

<AppLayout
  title={t`Transition demo without ClientRouter`}
  locale={locale}
  pathname={Astro.url.pathname}
  currentPage={currentPage}
>
  <TransitionShowcase
    locale={locale}
    clientRouter={false}
    pageLabel={t`No-router page A`}
    pageKey="a"
    nextHref="/transitions/no-router/b"
    nextLabel={t`No-router page B`}
  />
</AppLayout>
