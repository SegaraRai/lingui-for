{
  "name": "lingui5-svelte-vite7",
  "description": "SvelteKit compatibility fixture with Lingui 5 and the Vite 7-compatible Svelte plugin line.",
  "lingui": "5",
  "patches": [
    {
      "path": "examples/compat/sveltekit-basic/package.json",
      "sections": {
        "dependencies": {
          "@lingui/core": "^5.9.5"
        },
        "devDependencies": {
          "@lingui/cli": "^5.9.5",
          "@lingui/conf": "^5.9.5",
          "@sveltejs/vite-plugin-svelte": "^6.2.4"
        }
      }
    },
    {
      "path": "packages/lingui-for-svelte/package.json",
      "sections": {
        "devDependencies": {
          "@sveltejs/vite-plugin-svelte": "^6.2.4"
        }
      }
    }
  ],
  "projects": [
    {
      "cwd": "examples/compat/sveltekit-basic",
      "commands": [["vp", "run", "build"]]
    }
  ]
}
