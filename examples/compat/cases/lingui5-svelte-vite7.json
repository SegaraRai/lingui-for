{
  "name": "lingui5-svelte-vite7",
  "description": "SvelteKit compatibility fixture with Lingui 5 and the Vite 7-compatible Svelte plugin line.",
  "lingui": "5",
  "projects": [
    {
      "cwd": "examples/compat/projects/sveltekit-basic",
      "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "vite": "^7.2.7"
      },
      "localPackages": {
        "dependencies": ["lingui-for-svelte"],
        "devDependencies": ["unplugin-lingui-macro"]
      },
      "assertions": [
        {
          "cwd": "examples/compat/projects/sveltekit-basic",
          "name": "unplugin-lingui-macro",
          "major": "0"
        },
        {
          "cwd": "examples/compat/projects/sveltekit-basic",
          "name": "@lingui/babel-plugin-lingui-macro",
          "issuerPackage": "unplugin-lingui-macro",
          "major": "5"
        },
        {
          "cwd": "examples/compat/projects/sveltekit-basic",
          "name": "@sveltejs/vite-plugin-svelte",
          "major": "6"
        },
        {
          "cwd": "examples/compat/projects/sveltekit-basic",
          "name": "vite",
          "major": "7",
          "source": "moduleVersion"
        },
        {
          "cwd": "examples/compat/projects/sveltekit-basic",
          "name": "lingui-for-svelte",
          "major": "0"
        },
        {
          "cwd": "examples/compat/projects/sveltekit-basic",
          "name": "@lingui-for/framework-core",
          "issuerPackage": "lingui-for-svelte",
          "major": "0"
        }
      ],
      "commands": [
        ["lingui", "extract", "--clean", "--overwrite"],
        ["lingui", "compile"],
        ["svelte-kit", "sync"],
        ["vite", "build"]
      ],
      "snapshots": [
        "src/i18n/locales/en.po",
        "src/i18n/locales/ja.po",
        "src/i18n/locales/en.ts",
        "src/i18n/locales/ja.ts",
        "build/index.html"
      ]
    }
  ]
}
