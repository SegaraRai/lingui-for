{
  "name": "lingui6-svelte-vite8",
  "description": "SvelteKit compatibility fixture with Lingui 6 and the primary Vite 8-compatible Svelte plugin line.",
  "lingui": "6",
  "patches": [
    {
      "path": "examples/compat/sveltekit-basic/package.json",
      "sections": {
        "dependencies": {
          "@lingui/core": "^6.0.0"
        },
        "devDependencies": {
          "@lingui/cli": "^6.0.0",
          "@lingui/conf": "^6.0.0",
          "@sveltejs/vite-plugin-svelte": "^7.0.0"
        }
      }
    }
  ],
  "projects": [
    {
      "cwd": "examples/compat/sveltekit-basic",
      "commands": [["vp", "run", "build"]]
    }
  ]
}
