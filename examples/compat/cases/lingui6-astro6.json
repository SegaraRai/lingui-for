{
  "name": "lingui6-astro6",
  "description": "Astro compatibility fixture with Lingui 6 and the primary Astro 6 line.",
  "lingui": "6",
  "patches": [
    {
      "path": "examples/compat/astro-basic/package.json",
      "sections": {
        "dependencies": {
          "@lingui/core": "^6.0.0"
        },
        "devDependencies": {
          "@lingui/cli": "^6.0.0",
          "@lingui/conf": "^6.0.0"
        }
      }
    }
  ],
  "projects": [
    {
      "cwd": "examples/compat/astro-basic",
      "commands": [["vp", "run", "build"]]
    }
  ]
}
