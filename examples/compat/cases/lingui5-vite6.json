{
  "name": "lingui5-vite6",
  "description": "Plain Vite compatibility fixture with Lingui 5, Vite 6, and unplugin-lingui-macro.",
  "lingui": "5",
  "projects": [
    {
      "cwd": "examples/compat/projects/vite-basic",
      "devDependencies": {
        "vite": "^6.4.2"
      },
      "localPackages": {
        "devDependencies": ["unplugin-lingui-macro"]
      },
      "assertions": [
        {
          "cwd": "examples/compat/projects/vite-basic",
          "name": "unplugin-lingui-macro",
          "major": "0"
        },
        {
          "cwd": "examples/compat/projects/vite-basic",
          "name": "@lingui/babel-plugin-lingui-macro",
          "issuerPackage": "unplugin-lingui-macro",
          "major": "5"
        },
        {
          "cwd": "examples/compat/projects/vite-basic",
          "name": "vite",
          "major": "6",
          "source": "moduleVersion"
        }
      ],
      "commands": [
        ["lingui", "extract", "--clean", "--overwrite"],
        ["lingui", "compile"],
        ["vite", "build"]
      ],
      "snapshots": [
        "src/i18n/locales/en.po",
        "src/i18n/locales/ja.po",
        "src/i18n/locales/en.ts",
        "src/i18n/locales/ja.ts",
        "dist/main.js"
      ]
    }
  ]
}
