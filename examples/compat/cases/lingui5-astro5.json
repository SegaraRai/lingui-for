{
  "name": "lingui5-astro5",
  "description": "Astro compatibility fixture with Lingui 5 on the latest Astro 5 line.",
  "lingui": "5",
  "patches": [
    {
      "path": "examples/compat/astro-basic/package.json",
      "sections": {
        "dependencies": {
          "@lingui/core": "^5.9.5",
          "astro": "^5.17.3"
        },
        "devDependencies": {
          "@lingui/cli": "^5.9.5",
          "@lingui/conf": "^5.9.5"
        }
      }
    },
    {
      "path": "packages/lingui-for-astro/package.json",
      "sections": {
        "devDependencies": {
          "astro": "^5.17.3"
        }
      }
    }
  ],
  "projects": [
    {
      "cwd": "examples/compat/astro-basic",
      "commands": [["vp", "run", "build"]]
    }
  ]
}
