{
  "name": "lingui5-vite8",
  "description": "Plain Vite compatibility fixture with Lingui 5 and unplugin-lingui-macro.",
  "lingui": "5",
  "projects": [
    {
      "cwd": "examples/compat/vite-basic",
      "devDependencies": {
        "vite": "^8.0.0"
      },
      "localPackages": {
        "devDependencies": ["unplugin-lingui-macro"]
      },
      "assertions": [
        {
          "cwd": "examples/compat/vite-basic",
          "name": "unplugin-lingui-macro",
          "major": "0"
        },
        {
          "cwd": "examples/compat/vite-basic",
          "name": "@lingui/babel-plugin-lingui-macro",
          "issuerPackage": "unplugin-lingui-macro",
          "major": "5"
        },
        {
          "cwd": "examples/compat/vite-basic",
          "name": "vite",
          "major": "8",
          "source": "moduleVersion"
        }
      ],
      "commands": [
        ["lingui", "extract", "--clean", "--overwrite"],
        ["lingui", "compile"],
        ["vite", "build"]
      ]
    }
  ]
}
