{
  "name": "lingui-for-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "examples/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:e2e-svelte": "vp run --filter e2e-svelte dev",
    "dev:e2e-astro": "vp run --filter e2e-astro dev",
    "dev:docs": "vp run --filter docs dev",
    "preview:e2e-svelte": "vp run --filter e2e-svelte preview",
    "preview:e2e-astro": "vp run --filter e2e-astro preview",
    "preview:docs": "vp run --filter docs preview",
    "test:rust": "cargo test",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "catalog:",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.16",
    "vite-plus": "catalog:",
    "wasm-pack": "^0.14.0"
  },
  "packageManager": "pnpm@10.33.0"
}
