---
import { t } from "lingui-for-astro/macro";

import type { MacroWorkbenchControl } from "../lib/macro-workbench.ts";

type Props = {
  control: MacroWorkbenchControl;
};

const { control } = Astro.props as Props;
---

<div class="flex items-center gap-3">
  <div
    class="text-[0.7rem] font-medium tracking-[0.08em] text-(--demo-control-text) uppercase"
  >
    {t(control.label)}
  </div>

  {
    control.type === "text" ? (
      <input
        data-control-id={control.id}
        data-control-type="text"
        value={control.initial}
        placeholder={control.placeholder ? t(control.placeholder) : undefined}
        class:list={[
          "h-9 rounded-lg border border-(--demo-control-field-border) bg-(--demo-control-field-background) px-3 text-sm text-(--demo-control-field-text)",
          {
            sm: "w-28",
            md: "w-40",
            lg: "w-56",
          }[control.width ?? "md"],
        ]}
      />
    ) : control.type === "number" ? (
      <input
        data-control-id={control.id}
        data-control-type="number"
        type="number"
        value={String(control.initial)}
        min={control.min}
        max={control.max}
        step={control.step}
        class="h-9 w-24 rounded-lg border border-(--demo-control-field-border) bg-(--demo-control-field-background) px-3 text-sm text-(--demo-control-field-text)"
      />
    ) : control.type === "boolean" ? (
      <button
        type="button"
        aria-pressed={control.initial ? "true" : "false"}
        data-control-id={control.id}
        data-control-type="boolean"
        class="rounded-lg border border-(--demo-control-field-border) px-3 py-1.5 text-sm transition-colors aria-pressed:bg-(--demo-control-field-active-background) aria-pressed:text-(--demo-control-field-active-text) aria-[pressed=false]:text-(--demo-control-field-text)"
      >
        {control.initial ? "On" : "Off"}
      </button>
    ) : (
      <select
        data-control-id={control.id}
        data-control-type="select"
        value={control.initial}
        class="h-9 rounded-lg border border-(--demo-control-field-border) bg-(--demo-control-field-background) px-3 text-sm text-(--demo-control-field-text)"
      >
        {control.options.map((option) => (
          <option value={option.value}>{t(option.label)}</option>
        ))}
      </select>
    )
  }
</div>
