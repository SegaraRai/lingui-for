---
import { t } from "lingui-for-astro/macro";

import { ensureDocsLinguiContext, type DocsLocale } from "../lib/docs-i18n";
import type { MacroFamilyOverviewItem } from "../lib/macro-family-overview.ts";
import MacroFamilyOverview from "./MacroFamilyOverview.astro";

interface Props {
  language?: DocsLocale;
  hrefPrefix?: string;
}

const { language = "en", hrefPrefix = "" } = Astro.props;

ensureDocsLinguiContext(Astro.locals, language);

const items = [
  {
    value: "trans",
    label: t`Trans`,
    description: t`Translate rich text with embedded markup and placeholders.`,
    preview: t`Say hello to Lingui.`,
    snippet: String.raw`<Trans>
  Say hello to <strong>{name}</strong>.
</Trans>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/trans-component`,
  },
  {
    value: "plural",
    label: t`Plural`,
    description: t`Write plural ICU branches as component props in markup.`,
    preview: t`3 files`,
    snippet: String.raw`<Plural
  value={count}
  one="# file"
  other="# files"
/>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/plural-component`,
  },
  {
    value: "select",
    label: t`Select`,
    description: t`Write case-based selection as markup props.`,
    preview: t`Hi`,
    snippet: String.raw`<Select
  value={tone}
  _formal="Welcome"
  _casual="Hi"
  other="Hello"
/>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/select-component`,
  },
  {
    value: "select-ordinal",
    label: t`SelectOrdinal`,
    description: t`Write ordinal cases directly in component props.`,
    preview: t`1st`,
    snippet: String.raw`<SelectOrdinal
  value={place}
  one="#st"
  two="#nd"
  few="#rd"
  other="#th"
/>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/select-ordinal-component`,
  },
] satisfies readonly MacroFamilyOverviewItem[];
---

<MacroFamilyOverview title={t`Component Macro Overview`} {items} {language} />
