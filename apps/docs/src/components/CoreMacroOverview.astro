---
import { t } from "lingui-for-astro/macro";

import { ensureDocsLinguiContext, type DocsLocale } from "../lib/docs-i18n";
import type { MacroFamilyOverviewItem } from "../lib/macro-family-overview.ts";
import MacroFamilyOverview from "./MacroFamilyOverview.astro";

interface Props {
  language?: DocsLocale;
  hrefPrefix?: string;
}

const { language = "en", hrefPrefix = "" } = Astro.props;

ensureDocsLinguiContext(Astro.locals, language);

const items = [
  {
    value: "t",
    label: t`t`,
    description: t`Translate a message immediately and return a string.`,
    preview: t`Hello Lingui`,
    snippet: String.raw`<p>{
  $t\`Hello \${name}\`
}</p>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/t`,
  },
  {
    value: "msg",
    label: t`msg / defineMessage`,
    description: t`Define a descriptor now and translate it later.`,
    preview: t`Welcome back, Lingui`,
    snippet: String.raw`<script lang="ts">
  let welcome = $derived(msg\`Welcome back, \${name}\`);
</script>

<p>{$t(welcome)}</p>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/msg-and-define-message`,
  },
  {
    value: "plural",
    label: t`plural`,
    description: t`Pick text from plural categories based on a numeric count.`,
    preview: t`3 items`,
    snippet: String.raw`<p>{
  $plural(count, {
    one: "# item",
    other: "# items",
  })
}</p>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/plural`,
  },
  {
    value: "select",
    label: t`select`,
    description: t`Switch text by a named case such as tone or status.`,
    preview: t`Welcome`,
    snippet: String.raw`<p>{
  $select(tone, {
    formal: "Welcome",
    casual: "Hi",
    other: "Hello",
  })
}</p>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/select`,
  },
  {
    value: "select-ordinal",
    label: t`selectOrdinal`,
    description: t`Choose ordinal text such as 1st, 2nd, or 3rd.`,
    preview: t`2nd`,
    snippet: String.raw`<p>{
  $selectOrdinal(place, {
    one: "#st",
    two: "#nd",
    few: "#rd",
    other: "#th",
  })
}</p>`,
    snippetLang: "svelte",
    href: `${hrefPrefix}/macros/select-ordinal`,
  },
] satisfies readonly MacroFamilyOverviewItem[];
---

<MacroFamilyOverview title={t`Core Macro Overview`} {items} {language} />
