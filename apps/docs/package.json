{
  "name": "docs",
  "type": "module",
  "scripts": {
    "dev": "vp exec astro dev",
    "lingui:extract": "vp exec lingui extract --clean --overwrite",
    "lingui:compile": "vp exec lingui compile && vp fmt src/i18n/locales",
    "lingui:build": "vp run lingui:extract && vp run lingui:compile",
    "start": "vp exec astro dev",
    "build": "vp exec astro build",
    "preview": "vp exec astro preview",
    "check": "vp check && vp run check:ts",
    "check:ts": "vp exec astro check",
    "astro": "vp exec astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.1",
    "@astrojs/starlight-tailwind": "^5.0.0",
    "@astrojs/svelte": "^8.0.3",
    "@lingui/core": "^5.9.3",
    "@tailwindcss/vite": "4.2.2",
    "astro": "^6.0.7",
    "sharp": "^0.34.5",
    "svelte": "^5.54.0",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@lingui/cli": "^5.9.3",
    "@lingui/conf": "^5.9.3",
    "@lingui/format-po": "^5.9.3",
    "astro-strip-whitespace": "^0.2.1",
    "lingui-for-astro": "workspace:*",
    "lingui-for-svelte": "workspace:*",
    "shiki": "^4.0.2",
    "unplugin-lingui-macro": "workspace:*",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
