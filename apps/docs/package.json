{
  "name": "docs",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "lingui:extract": "lingui extract --clean --overwrite",
    "lingui:compile": "lingui compile && prettier --write src/i18n/locales",
    "lingui:build": "pnpm run lingui:extract && pnpm run lingui:compile",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "pnpm run check:ts",
    "check:ts": "astro check",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.1",
    "@lingui/core": "^5.9.3",
    "astro": "^6.0.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@lingui/cli": "^5.9.3",
    "lingui-for-svelte": "workspace:*"
  }
}
