---
import { createLinguiAccessors as __l4a_createI18n } from "lingui-for-astro/runtime";
const __l4a_i18n = __l4a_createI18n(Astro.locals);
import { RuntimeTrans as L4aRuntimeTrans } from "lingui-for-astro/runtime";

const localeLabel = "日本語";
const selectedPath: string | null = "/資料/レビュー/案内😀.md";
const relatedPaths = ["/資料/概要.md", "/案内/導入👨‍👩‍👧‍👦.md", "/履歴/更新🙂.md"];

const headline = __l4a_i18n._(
/** i18n */
{
  id: "bzKC4u",
  message: "ようこそ {localeLabel}",
  values: {
    localeLabel: localeLabel
  }
});
const summary = __l4a_i18n._(
/** i18n */
// Note that this method is actually not recommended for complex messages with multiple variables.
// It's better to use `select` or `plural` for such cases.
{
  id: "DSRd7_",
  message: "参照中のパスは {0} で、候補は {1} です。",
  values: {
    0: String(selectedPath ?? __l4a_i18n._(
    /** i18n */
    {
      id: "ggPEgU",
      message: "未設定"
    })),
    1: String(relatedPaths[1] ?? __l4a_i18n._(
    /** i18n */
    {
      id: "gkv1jV",
      message: "ありません"
    }))
  }
});
__l4a_i18n.prime();
---

<main class="grid gap-4 p-6">
  <h1 class="text-2xl font-semibold">{headline}</h1>
  <p class="text-sm">{summary}</p>
  <p class="text-sm">
    <L4aRuntimeTrans placeholders={["0", "1"]} {...(/*i18n*/ {
      id: "fgdhx6",
      message: "ロケール <0>{localeLabel}</0> で <1>{0}</1> を確認しています。",
      values: {
        0: String(selectedPath ?? ""),
        localeLabel: localeLabel
      }
    })}>
    <fragment slot="component_0">{(children) => <strong><Fragment set:html={children} /></strong>}</fragment>
    <fragment slot="component_1">{(children) => <span><Fragment set:html={children} /></span>}</fragment>
    </L4aRuntimeTrans>
  </p>
  <ul class="grid gap-2">
    {
      relatedPaths.map((path) => (
        <li class="rounded border px-3 py-2">
          {__l4a_i18n._(
          /** i18n */
          {
            id: "AUUW5v",
            message: "候補パス: {0}",
            values: {
              0: String(path ?? "")
            }
          })}
        </li>
      ))
    }
  </ul>
</main>
