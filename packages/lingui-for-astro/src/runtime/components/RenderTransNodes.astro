---
import type { TransComponentMap, TransRenderNode } from "./types.ts";

interface Props {
  nodes: readonly TransRenderNode[];
  components: TransComponentMap;
}

const { nodes, components } = Astro.props;
---

{
  nodes.map((node) => {
    const descriptor =
      typeof node === "string" ? null : (components[node.placeholder] ?? null);

    return typeof node === "string" ? (
      node
    ) : descriptor?.kind === "element" ? (
      <descriptor.tag {...(descriptor.props ?? {})}>
        <Astro.self nodes={node.children} components={components} />
      </descriptor.tag>
    ) : descriptor?.kind === "component" ? (
      <descriptor.component {...(descriptor.props ?? {})}>
        <Astro.self nodes={node.children} components={components} />
      </descriptor.component>
    ) : (
      <Astro.self nodes={node.children} components={components} />
    );
  })
}
