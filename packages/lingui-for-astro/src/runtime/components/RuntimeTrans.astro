---
import { formatRichTextTranslation } from "@lingui-for/internal-shared-runtime";

import { getLinguiContext } from "../core/context.ts";
import type { TransRenderNode } from "./types.ts";

interface Props {
  id: string;
  message?: string | undefined;
  values?: Readonly<Record<string, unknown>> | undefined;
  placeholders?: readonly string[] | undefined;
}

const { id, message, values = {}, placeholders } = Astro.props;
const options = message != null ? { message } : {};

const { i18n } = getLinguiContext(Astro.locals);
const translated = i18n._(id, values, options);

function escapeHtml(value: string): string {
  // Matches with Astro's html escaping, which uses html-escaper.
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

const placeholderMap =
  placeholders && placeholders.length > 0
    ? Object.fromEntries(
        placeholders.map((placeholder) => [placeholder, true] as const),
      )
    : null;
const nodes = placeholderMap
  ? formatRichTextTranslation(translated, placeholderMap)
  : [];

async function renderNodes(
  nodesToRender: readonly TransRenderNode[],
): Promise<string> {
  const chunks = await Promise.all(
    nodesToRender.map(async (node) => {
      if (typeof node === "string") {
        return escapeHtml(node);
      }

      const childrenHtml = await renderNodes(node.children);
      const slotName = `component_${node.placeholder}`;
      if (!Astro.slots.has(slotName)) {
        return childrenHtml;
      }

      return await Astro.slots.render(slotName, [childrenHtml]);
    }),
  );

  return chunks.join("");
}

const html = placeholderMap ? await renderNodes(nodes) : null;
---

{html == null ? translated : <Fragment set:html={html} />}
