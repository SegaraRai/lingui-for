---
import type { TransComponentMap, TransRenderNode } from "./rich-text.ts";

import RenderTransNodes from "./RenderTransNodes.astro";

interface Props {
  node: TransRenderNode;
  components: TransComponentMap;
}

const { node, components } = Astro.props;

const descriptor =
  typeof node === "string" ? null : (components[node.name] ?? null);
---

{
  typeof node === "string" ? (
    node
  ) : descriptor?.kind === "element" ? (
    <descriptor.tag {...(descriptor.props ?? {})}>
      <RenderTransNodes nodes={node.children} components={components} />
    </descriptor.tag>
  ) : descriptor?.kind === "component" ? (
    <descriptor.component {...(descriptor.props ?? {})}>
      <RenderTransNodes nodes={node.children} components={components} />
    </descriptor.component>
  ) : (
    <RenderTransNodes nodes={node.children} components={components} />
  )
}
