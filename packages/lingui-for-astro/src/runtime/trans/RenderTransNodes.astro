---
import type { TransComponentMap, TransRenderNode } from "./rich-text.ts";

import RenderTransNode from "./RenderTransNode.astro";

const {
  nodes,
  components,
}: {
  nodes: readonly TransRenderNode[];
  components: TransComponentMap;
} = Astro.props;
---

{nodes.map((node) => <RenderTransNode node={node} components={components} />)}
