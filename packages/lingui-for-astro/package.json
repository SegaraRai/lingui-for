{
  "name": "lingui-for-astro",
  "version": "0.4.0",
  "description": "Macro-first Lingui integration for Astro.",
  "keywords": [
    "astro",
    "esbuild",
    "i18n",
    "lingui",
    "rolldown",
    "rollup",
    "rspack",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://lingui-for.roundtrip.dev/frameworks/astro/getting-started",
  "bugs": {
    "url": "https://github.com/SegaraRai/lingui-for/issues"
  },
  "license": "MIT",
  "author": "SegaraRai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SegaraRai/lingui-for.git",
    "directory": "packages/lingui-for-astro"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.astro",
    "./runtime",
    "./dist/runtime/index.mjs"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./extractor": {
      "types": "./dist/extractor.d.mts",
      "default": "./dist/extractor.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "default": "./dist/config.mjs"
    },
    "./macro": {
      "types": "./dist/macro.d.mts",
      "default": "./dist/macro.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "default": "./dist/runtime/index.mjs"
    },
    "./integration": {
      "types": "./dist/integration/index.d.mts",
      "default": "./dist/integration/index.mjs"
    },
    "./unplugin": {
      "types": "./dist/unplugin/index.d.mts",
      "default": "./dist/unplugin/index.mjs"
    },
    "./unplugin/types": {
      "types": "./dist/unplugin/types.d.mts",
      "default": "./dist/unplugin/types.mjs"
    },
    "./unplugin/bun": {
      "types": "./dist/unplugin/bun.d.mts",
      "default": "./dist/unplugin/bun.mjs"
    },
    "./unplugin/esbuild": {
      "types": "./dist/unplugin/esbuild.d.mts",
      "default": "./dist/unplugin/esbuild.mjs"
    },
    "./unplugin/rolldown": {
      "types": "./dist/unplugin/rolldown.d.mts",
      "default": "./dist/unplugin/rolldown.mjs"
    },
    "./unplugin/rollup": {
      "types": "./dist/unplugin/rollup.d.mts",
      "default": "./dist/unplugin/rollup.mjs"
    },
    "./unplugin/rspack": {
      "types": "./dist/unplugin/rspack.d.mts",
      "default": "./dist/unplugin/rspack.mjs"
    },
    "./unplugin/vite": {
      "types": "./dist/unplugin/vite.d.mts",
      "default": "./dist/unplugin/vite.mjs"
    },
    "./unplugin/webpack": {
      "types": "./dist/unplugin/webpack.d.mts",
      "default": "./dist/unplugin/webpack.mjs"
    },
    "./internal/compile": {
      "types": "./dist/internal/compile.d.mts",
      "default": "./dist/internal/compile.mjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@lingui-for/framework-core": "workspace:*",
    "@lingui/babel-plugin-lingui-macro": "^5.0.0",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@lingui-for/internal-shared-test-helpers": "workspace:*",
    "@lingui/cli": "^5.9.5",
    "@lingui/conf": "^5.9.5",
    "@lingui/core": "^5.9.5",
    "@types/node": "catalog:",
    "astro": "^6.1.5",
    "dedent": "^1.7.2",
    "typescript": "catalog:",
    "unplugin-markup-import": "workspace:*",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@lingui/cli": "^5.0.0",
    "@lingui/conf": "^5.0.0",
    "@lingui/core": "^5.0.0",
    "astro": "^5 || ^6",
    "esbuild": "*",
    "rolldown": "^1.0.0-0",
    "rollup": "^3 || ^4",
    "vite": ">=3",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@lingui/conf": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  }
}
