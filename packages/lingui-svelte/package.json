{
  "name": "lingui-svelte",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/runtime/index.mjs",
  "svelte": "./dist/runtime/index.mjs",
  "types": "./dist/runtime/index.d.mts",
  "sideEffects": [
    "**/*.svelte"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts && node ./scripts/copy-trans.mjs"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.mts",
      "svelte": "./dist/runtime/index.mjs",
      "default": "./dist/runtime/index.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "svelte": "./dist/runtime/index.mjs",
      "default": "./dist/runtime/index.mjs"
    },
    "./macro": {
      "types": "./dist/macro/index.d.mts",
      "default": "./dist/macro/index.mjs"
    },
    "./unplugin": {
      "types": "./dist/unplugin/index.d.mts",
      "default": "./dist/unplugin/index.mjs"
    },
    "./extractor": {
      "types": "./dist/extractor/index.d.mts",
      "default": "./dist/extractor/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@lingui/core": "^5.9.2",
    "svelte": "^5.53.10"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/types": "^7.29.0",
    "@lingui/babel-plugin-lingui-macro": "^5.9.2",
    "@lingui/cli": "^5.9.2",
    "@lingui/conf": "^5.9.2",
    "@lingui/core": "^5.9.2",
    "@typescript-eslint/typescript-estree": "^8.57.0",
    "estree-walker-ts": "^1.1.0",
    "magic-string": "^0.30.21",
    "source-map": "^0.7.6",
    "unplugin": "^3.0.0"
  }
}
