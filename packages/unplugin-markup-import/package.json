{
  "name": "unplugin-markup-import",
  "version": "0.1.1",
  "description": "Unplugin for including .svelte and .astro files in bundler output with correct import graph resolution.",
  "homepage": "https://github.com/SegaraRai/lingui-for/tree/main/packages/unplugin-markup-import#readme",
  "bugs": {
    "url": "https://github.com/SegaraRai/lingui-for/issues"
  },
  "license": "MIT",
  "author": "SegaraRai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SegaraRai/lingui-for.git",
    "directory": "packages/unplugin-markup-import"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    },
    "./bun": {
      "types": "./dist/bun.d.mts",
      "default": "./dist/bun.mjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.mts",
      "default": "./dist/esbuild.mjs"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.mts",
      "default": "./dist/rolldown.mjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.mts",
      "default": "./dist/rollup.mjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.mts",
      "default": "./dist/rspack.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "default": "./dist/vite.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "default": "./dist/webpack.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp run check:ts",
    "check:ts": "vp check && vp exec tsc -b --noEmit",
    "test": "vp test"
  },
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.57.1",
