{
  "name": "unplugin-lingui-macro",
  "version": "0.3.0",
  "description": "Bundler plugin for compiling Lingui macros in plain JavaScript and TypeScript modules.",
  "keywords": [
    "esbuild",
    "i18n",
    "lingui",
    "rolldown",
    "rollup",
    "rspack",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://lingui-for.roundtrip.dev/guides/install-and-first-translation",
  "bugs": {
    "url": "https://github.com/SegaraRai/lingui-for/issues"
  },
  "license": "MIT",
  "author": "SegaraRai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SegaraRai/lingui-for.git",
    "directory": "packages/unplugin-lingui-macro"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "default": "./dist/types.mjs"
    },
    "./bun": {
      "types": "./dist/bun.d.mts",
      "default": "./dist/bun.mjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.mts",
      "default": "./dist/esbuild.mjs"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.mts",
      "default": "./dist/rolldown.mjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.mts",
      "default": "./dist/rollup.mjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.mts",
      "default": "./dist/rspack.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "default": "./dist/vite.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "default": "./dist/webpack.mjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@lingui/babel-plugin-lingui-macro": "^5.0.0",
    "oxc-parser": ">=0.100.0 <1.0.0",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@lingui-for/internal-shared-common": "workspace:*",
    "@lingui/conf": "^5.9.5",
    "@types/babel__core": "^7.20.5",
    "@types/node": "catalog:",
    "dedent": "^1.7.2",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@lingui/conf": "^5.0.0",
    "esbuild": "*",
    "rolldown": "^1.0.0-0",
    "rollup": "^3 || ^4",
    "vite": ">=3",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@lingui/conf": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  }
}
