{
  "name": "lingui-for-svelte",
  "version": "0.7.0",
  "description": "Macro-first Lingui integration for Svelte 5.",
  "keywords": [
    "esbuild",
    "i18n",
    "lingui",
    "rolldown",
    "rollup",
    "rspack",
    "svelte",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://lingui-for.roundtrip.dev/frameworks/svelte/getting-started",
  "bugs": {
    "url": "https://github.com/SegaraRai/lingui-for/issues"
  },
  "license": "MIT",
  "author": "SegaraRai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SegaraRai/lingui-for.git",
    "directory": "packages/lingui-for-svelte"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.svelte",
    "./runtime",
    "./dist/runtime/index.mjs"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "svelte": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "svelte": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./extractor": {
      "types": "./dist/extractor.d.mts",
      "default": "./dist/extractor.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "default": "./dist/config.mjs"
    },
    "./macro": {
      "types": "./dist/macro.d.mts",
      "svelte": "./dist/macro.mjs",
      "default": "./dist/macro.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "svelte": "./dist/runtime/index.mjs",
      "default": "./dist/runtime/index.mjs"
    },
    "./unplugin": {
      "types": "./dist/unplugin/index.d.mts",
      "default": "./dist/unplugin/index.mjs"
    },
    "./unplugin/types": {
      "types": "./dist/unplugin/types.d.mts",
      "default": "./dist/unplugin/types.mjs"
    },
    "./unplugin/bun": {
      "types": "./dist/unplugin/bun.d.mts",
      "default": "./dist/unplugin/bun.mjs"
    },
    "./unplugin/esbuild": {
      "types": "./dist/unplugin/esbuild.d.mts",
      "default": "./dist/unplugin/esbuild.mjs"
    },
    "./unplugin/rolldown": {
      "types": "./dist/unplugin/rolldown.d.mts",
      "default": "./dist/unplugin/rolldown.mjs"
    },
    "./unplugin/rollup": {
      "types": "./dist/unplugin/rollup.d.mts",
      "default": "./dist/unplugin/rollup.mjs"
    },
    "./unplugin/rspack": {
      "types": "./dist/unplugin/rspack.d.mts",
      "default": "./dist/unplugin/rspack.mjs"
    },
    "./unplugin/vite": {
      "types": "./dist/unplugin/vite.d.mts",
      "default": "./dist/unplugin/vite.mjs"
    },
    "./unplugin/webpack": {
      "types": "./dist/unplugin/webpack.d.mts",
      "default": "./dist/unplugin/webpack.mjs"
    },
    "./internal/compile": {
      "types": "./dist/internal/compile.d.mts",
      "default": "./dist/internal/compile.mjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@lingui-for/framework-core": "workspace:*",
    "@lingui/babel-plugin-lingui-macro": "catalog:dep",
    "unplugin": "catalog:dep"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@jridgewell/trace-mapping": "catalog:",
    "@lingui-for/internal-shared-test-helpers": "workspace:*",
    "@lingui/cli": "catalog:",
    "@lingui/conf": "catalog:",
    "@lingui/core": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@types/node": "catalog:",
    "dedent": "catalog:",
    "svelte": "catalog:",
    "typescript": "catalog:",
    "unplugin-markup-import": "workspace:*",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@lingui/cli": "catalog:dep",
    "@lingui/conf": "catalog:dep",
    "@lingui/core": "catalog:dep",
    "esbuild": "catalog:dep",
    "rolldown": "catalog:dep",
    "rollup": "catalog:dep",
    "svelte": "catalog:dep",
    "vite": "catalog:dep",
    "webpack": "catalog:dep"
  },
  "peerDependenciesMeta": {
    "@lingui/conf": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  }
}
