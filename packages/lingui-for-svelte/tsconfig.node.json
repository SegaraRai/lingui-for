{
  "compilerOptions": {
    "composite": true,
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "Bundler",
    "lib": ["ES2024"],
    "strict": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vitest.config.ts"]
}
