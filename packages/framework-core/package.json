{
  "name": "@lingui-for/framework-core",
  "version": "0.5.1",
  "description": "Shared framework compile and runtime helpers for lingui-for packages.",
  "license": "MIT",
  "author": "SegaraRai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SegaraRai/lingui-for.git",
    "directory": "packages/framework-core"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./compile": {
      "types": "./dist/compile/index.d.mts",
      "default": "./dist/compile/index.mjs"
    },
    "./compile/wasm-loader": {
      "types": "./dist/compile/wasm-loader.d.mts",
      "default": "./dist/compile/wasm-loader.mjs"
    },
    "./compile/wasm-loader-vite": {
      "types": "./dist/compile/wasm-loader-vite.d.mts",
      "default": "./dist/compile/wasm-loader-vite.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "default": "./dist/config.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "default": "./dist/runtime/index.mjs"
    },
    "./vendor/babel-core": {
      "types": "./dist/vendor/babel-core.d.mts",
      "default": "./dist/vendor/babel-core.mjs"
    },
    "./vendor/babel-types": {
      "types": "./dist/vendor/babel-types.d.mts",
      "default": "./dist/vendor/babel-types.mjs"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "cosmiconfig": "^9.0.1",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@lingui-for/internal-lingui-analyzer-wasm": "workspace:*",
    "@lingui-for/internal-shared-common": "workspace:*",
    "@lingui/cli": "^5.9.5",
    "@lingui/conf": "^5.9.5",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "catalog:",
    "dedent": "^1.7.2",
    "rolldown-plugin-wasm": "^0.2.1",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@lingui/cli": "^5.0.0",
    "@lingui/conf": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@lingui/conf": {
      "optional": true
    }
  }
}
